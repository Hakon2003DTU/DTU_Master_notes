

library ieee;
use ieee.std_logic_1164.all;

entity This_is_a_test_tb is
-- Empty entity for testbench
end entity This_is_a_test_tb;

architecture sim of This_is_a_test_tb is

    -- Signals to connect to the Device Under Test (DUT)
    signal sw_tb  : std_logic_vector(9 downto 0) := (others => '0');
    signal led_tb : std_logic_vector(9 downto 0);

begin

    -- 1. Instantiate the Unit Under Test (UUT)
    DUT: entity work.This_is_a_test
        port map (
            SW  => sw_tb,
            LED => led_tb
        );

    -- 2. Stimulus process (the testing logic)
    process
    begin
        -- Test Case 1: All switches OFF
        sw_tb <= "0000000000";
        wait for 20 ns;

        -- Test Case 2: All switches ON
        sw_tb <= "1111111111";
        wait for 20 ns;

        -- Test Case 3: Alternating pattern
        sw_tb <= "1010101010";
        wait for 20 ns;

        wait; -- Stop the simulation here
    end process;

end architecture sim;








